# Copia este archivo como .env.docker en el servidor. Nunca publiques
# .env.docker ni reemplaces estos marcadores por secretos dentro de Git.
SECRET_KEY=REEMPLAZAR_CON_UN_VALOR_ALEATORIO_DE_50_CARACTERES_O_MAS
DEBUG=False
APP_DOMAIN=inversionescahuana.com
ALLOWED_HOSTS=inversionescahuana.com,www.inversionescahuana.com,54.159.214.66,localhost,127.0.0.1

DB_NAME=inversiones_cahuana
DB_USER=cahuana
DB_PASSWORD=REEMPLAZAR_CON_UNA_CLAVE_ALEATORIA_Y_UNICA

FRONTEND_URL=https://inversionescahuana.com
CORS_ALLOWED_ORIGINS=https://inversionescahuana.com,https://www.inversionescahuana.com
CSRF_TRUSTED_ORIGINS=https://inversionescahuana.com,https://www.inversionescahuana.com

# Se activarán cuando el dominio tenga HTTPS.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
